{
  "name": "mbn-theme",
  "version": "1.1.1",
  "private": true,
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "wp-scripts build",
    "build:css": "node node_modules/tailwindcss/lib/cli.js -i ./resources/css/app.css -o ./assets/build/tailwind.css --minify",
    "start:js": "wp-scripts start",
    "watch:css": "node node_modules/tailwindcss/lib/cli.js -i ./resources/css/app.css -o ./assets/build/tailwind.css --watch",
    "dev": "npm-run-all --parallel start:js watch:css",
    "bundle": "node scripts/bundle.mjs",
    "lint:php": "composer run lint",
    "lint:php:fix": "composer run lint:fix"
  },
  "devDependencies": {
    "@wordpress/scripts": "^32.5.0",
    "autoprefixer": "^10.4.20",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
