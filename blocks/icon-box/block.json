{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mbn-theme/icon-box",
  "title": "Icon Box",
  "category": "mbn-blocks",
  "icon": "star-filled",
  "description": "Display an icon with title, description and button.",
  "keywords": ["icon", "box", "feature"],
  "textdomain": "mbn-theme",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "iconImageId":              { "type": "number",  "default": 0 },
    "iconImageUrl":             { "type": "string",  "default": "" },
    "iconImageAlt":             { "type": "string",  "default": "" },
    "iconSvgCode":              { "type": "string",  "default": "" },
    "iconType":                 { "type": "string",  "default": "image" },
    "iconBgColor":              { "type": "string",  "default": "" },
    "iconShape":                { "type": "string",  "default": "none" },
    "iconBorderStyle":          { "type": "string",  "default": "none" },
    "iconBorderWidth":          { "type": "string",  "default": "" },
    "iconBorderColor":          { "type": "string",  "default": "" },
    "iconBorderRadius":         { "type": "string",  "default": "" },
    "iconPaddingTop":           { "type": "string",  "default": "" },
    "iconPaddingRight":         { "type": "string",  "default": "" },
    "iconPaddingBottom":        { "type": "string",  "default": "" },
    "iconPaddingLeft":          { "type": "string",  "default": "" },
    "iconMarginTop":            { "type": "string",  "default": "" },
    "iconMarginRight":          { "type": "string",  "default": "" },
    "iconMarginBottom":         { "type": "string",  "default": "" },
    "iconMarginLeft":           { "type": "string",  "default": "" },
    "iconWidth":                { "type": "string",  "default": "" },

    "titleTag":                 { "type": "string",  "default": "h3" },
    "title":                    { "type": "string",  "default": "" },
    "titleMaxWidth":            { "type": "string",  "default": "" },
    "titleMarginTop":           { "type": "string",  "default": "" },
    "titleMarginRight":         { "type": "string",  "default": "" },
    "titleMarginBottom":        { "type": "string",  "default": "" },
    "titleMarginLeft":          { "type": "string",  "default": "" },
    "titlePaddingTop":          { "type": "string",  "default": "" },
    "titlePaddingRight":        { "type": "string",  "default": "" },
    "titlePaddingBottom":       { "type": "string",  "default": "" },
    "titlePaddingLeft":         { "type": "string",  "default": "" },
    "titleFontFamily":          { "type": "string",  "default": "" },
    "titleFontSize":            { "type": "string",  "default": "" },
    "titleFontWeight":          { "type": "string",  "default": "" },
    "titleLineHeight":          { "type": "string",  "default": "" },
    "titleLetterSpacing":       { "type": "string",  "default": "" },
    "titleColor":               { "type": "string",  "default": "" },
    "titleAlign":               { "type": "string",  "default": "" },

    "description":              { "type": "string",  "default": "" },
    "descriptionMaxWidth":      { "type": "string",  "default": "" },
    "descriptionMarginTop":     { "type": "string",  "default": "" },
    "descriptionMarginRight":   { "type": "string",  "default": "" },
    "descriptionMarginBottom":  { "type": "string",  "default": "" },
    "descriptionMarginLeft":    { "type": "string",  "default": "" },
    "descriptionPaddingTop":    { "type": "string",  "default": "" },
    "descriptionPaddingRight":  { "type": "string",  "default": "" },
    "descriptionPaddingBottom": { "type": "string",  "default": "" },
    "descriptionPaddingLeft":   { "type": "string",  "default": "" },
    "descriptionFontFamily":    { "type": "string",  "default": "" },
    "descriptionFontSize":      { "type": "string",  "default": "" },
    "descriptionFontWeight":    { "type": "string",  "default": "" },
    "descriptionLineHeight":    { "type": "string",  "default": "" },
    "descriptionLetterSpacing": { "type": "string",  "default": "" },
    "descriptionColor":         { "type": "string",  "default": "" },
    "descriptionAlign":         { "type": "string",  "default": "" },

    "buttonText":               { "type": "string",  "default": "" },
    "buttonUrl":                { "type": "string",  "default": "" },
    "buttonTarget":             { "type": "string",  "default": "_self" },
    "buttonStyle":              { "type": "string",  "default": "primary" },
    "buttonMarginTop":          { "type": "string",  "default": "" },
    "buttonMarginRight":        { "type": "string",  "default": "" },
    "buttonMarginBottom":       { "type": "string",  "default": "" },
    "buttonMarginLeft":         { "type": "string",  "default": "" },
    "buttonPaddingTop":         { "type": "string",  "default": "" },
    "buttonPaddingRight":       { "type": "string",  "default": "" },
    "buttonPaddingBottom":      { "type": "string",  "default": "" },
    "buttonPaddingLeft":        { "type": "string",  "default": "" },
    "buttonFontFamily":         { "type": "string",  "default": "" },
    "buttonFontSize":           { "type": "string",  "default": "" },
    "buttonFontWeight":         { "type": "string",  "default": "" },
    "buttonBorderStyle":        { "type": "string",  "default": "none" },
    "buttonBorderWidth":        { "type": "string",  "default": "" },
    "buttonBorderColor":        { "type": "string",  "default": "" },
    "buttonBorderRadius":       { "type": "string",  "default": "" },

    "contentPosition":          { "type": "string",  "default": "center" },
    "containerWidth":           { "type": "string",  "default": "" },
    "containerPaddingTop":      { "type": "string",  "default": "" },
    "containerPaddingRight":    { "type": "string",  "default": "" },
    "containerPaddingBottom":   { "type": "string",  "default": "" },
    "containerPaddingLeft":     { "type": "string",  "default": "" },
    "containerMarginTop":       { "type": "string",  "default": "" },
    "containerMarginRight":     { "type": "string",  "default": "" },
    "containerMarginBottom":    { "type": "string",  "default": "" },
    "containerMarginLeft":      { "type": "string",  "default": "" },
    "containerBgType":          { "type": "string",  "default": "color" },
    "containerBgColor":         { "type": "string",  "default": "" },
    "containerBgGradient":      { "type": "string",  "default": "" },
    "containerBgImageUrl":      { "type": "string",  "default": "" },
    "containerBgImageId":       { "type": "number",  "default": 0 },
    "containerBgImageSize":     { "type": "string",  "default": "cover" },
    "containerBgImagePosition": { "type": "string",  "default": "center center" },
    "containerBorderRadius":    { "type": "string",  "default": "" },
    "containerBorderStyle":     { "type": "string",  "default": "none" },
    "containerBorderWidth":     { "type": "string",  "default": "" },
    "containerBorderColor":     { "type": "string",  "default": "" },
    "containerShadow":          { "type": "string",  "default": "none" },
    "containerShadowCustom":    { "type": "string",  "default": "" },
    "boxLinkUrl":               { "type": "string",  "default": "" },
    "boxLinkTarget":            { "type": "string",  "default": "_self" },
    "blockId":                  { "type": "string",  "default": "" },
    "customCss":                { "type": "string",  "default": "" }
  }
}
