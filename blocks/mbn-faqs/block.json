{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mbn-theme/mbn-faqs",
  "title": "MBN FAQs",
  "category": "mbn-blocks",
  "icon": "editor-ul",
  "description": "Accordion-style FAQ block with repeater items and full typography controls.",
  "keywords": ["faq", "accordion", "faqs", "questions"],
  "textdomain": "mbn-theme",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "alignment":            { "type": "string", "default": "left" },
    "bgType":               { "type": "string", "default": "color" },
    "bgColor":              { "type": "string", "default": "" },
    "bgGradient":           { "type": "string", "default": "" },
    "bgImageUrl":           { "type": "string", "default": "" },
    "bgImageId":            { "type": "number", "default": 0 },
    "bgImageSize":          { "type": "string", "default": "cover" },
    "bgImagePosition":      { "type": "string", "default": "center center" },
    "borderStyle":          { "type": "string", "default": "none" },
    "borderWidth":          { "type": "string", "default": "" },
    "borderColor":          { "type": "string", "default": "" },
    "borderRadius":         { "type": "string", "default": "" },
    "paddingTop":           { "type": "string", "default": "" },
    "paddingRight":         { "type": "string", "default": "" },
    "paddingBottom":        { "type": "string", "default": "" },
    "paddingLeft":          { "type": "string", "default": "" },
    "marginTop":            { "type": "string", "default": "" },
    "marginRight":          { "type": "string", "default": "" },
    "marginBottom":         { "type": "string", "default": "" },
    "marginLeft":           { "type": "string", "default": "" },
    "containerWidth":       { "type": "string", "default": "" },

    "items": {
      "type": "array",
      "default": [],
      "items": { "type": "object" }
    },

    "questionTag":            { "type": "string", "default": "h3" },
    "questionMarginTop":      { "type": "string", "default": "" },
    "questionMarginRight":    { "type": "string", "default": "" },
    "questionMarginBottom":   { "type": "string", "default": "" },
    "questionMarginLeft":     { "type": "string", "default": "" },
    "questionPaddingTop":     { "type": "string", "default": "" },
    "questionPaddingRight":   { "type": "string", "default": "" },
    "questionPaddingBottom":  { "type": "string", "default": "" },
    "questionPaddingLeft":    { "type": "string", "default": "" },
    "questionMaxWidth":       { "type": "string", "default": "" },
    "questionFontFamily":     { "type": "string", "default": "" },
    "questionFontSize":       { "type": "string", "default": "" },
    "questionFontWeight":     { "type": "string", "default": "" },
    "questionLineHeight":     { "type": "string", "default": "" },
    "questionLetterSpacing":  { "type": "string", "default": "" },
    "questionColor":          { "type": "string", "default": "" },
    "questionAlign":          { "type": "string", "default": "" },

    "answerMarginTop":        { "type": "string", "default": "" },
    "answerMarginRight":      { "type": "string", "default": "" },
    "answerMarginBottom":     { "type": "string", "default": "" },
    "answerMarginLeft":       { "type": "string", "default": "" },
    "answerPaddingTop":       { "type": "string", "default": "" },
    "answerPaddingRight":     { "type": "string", "default": "" },
    "answerPaddingBottom":    { "type": "string", "default": "" },
    "answerPaddingLeft":      { "type": "string", "default": "" },
    "answerMaxWidth":         { "type": "string", "default": "" },
    "answerFontFamily":       { "type": "string", "default": "" },
    "answerFontSize":         { "type": "string", "default": "" },
    "answerFontWeight":       { "type": "string", "default": "" },
    "answerLineHeight":       { "type": "string", "default": "" },
    "answerLetterSpacing":    { "type": "string", "default": "" },
    "answerColor":            { "type": "string", "default": "" },
    "answerAlign":            { "type": "string", "default": "" },

    "blockId":    { "type": "string", "default": "" },
    "customId":   { "type": "string", "default": "" },
    "customClass":{ "type": "string", "default": "" },
    "customCss":  { "type": "string", "default": "" }
  }
}
