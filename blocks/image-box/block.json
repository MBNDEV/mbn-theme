{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mbn-theme/image-box",
  "title": "Image Box",
  "category": "mbn-blocks",
  "icon": "format-image",
  "description": "Image box with content, buttons, and full design controls.",
  "textdomain": "mbn-theme",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./render.php",
  "attributes": {
    "imageId":                  { "type": "number",  "default": 0 },
    "imageUrl":                 { "type": "string",  "default": "" },
    "imageAlt":                 { "type": "string",  "default": "" },
    "imageSize":                { "type": "string",  "default": "full" },
    "imageWidth":               { "type": "string",  "default": "" },
    "imageHeight":              { "type": "string",  "default": "" },
    "imageObjectFit":           { "type": "string",  "default": "cover" },
    "imageMarginTop":           { "type": "string",  "default": "" },
    "imageMarginRight":         { "type": "string",  "default": "" },
    "imageMarginBottom":        { "type": "string",  "default": "" },
    "imageMarginLeft":          { "type": "string",  "default": "" },

    "titleTag":                 { "type": "string",  "default": "h2" },
    "title":                    { "type": "string",  "default": "" },
    "titleMaxWidth":            { "type": "string",  "default": "" },
    "titleMarginTop":           { "type": "string",  "default": "" },
    "titleMarginRight":         { "type": "string",  "default": "" },
    "titleMarginBottom":        { "type": "string",  "default": "" },
    "titleMarginLeft":          { "type": "string",  "default": "" },
    "titlePaddingTop":          { "type": "string",  "default": "" },
    "titlePaddingRight":        { "type": "string",  "default": "" },
    "titlePaddingBottom":       { "type": "string",  "default": "" },
    "titlePaddingLeft":         { "type": "string",  "default": "" },
    "titleFontFamily":          { "type": "string",  "default": "" },
    "titleFontSize":            { "type": "string",  "default": "" },
    "titleFontWeight":          { "type": "string",  "default": "" },
    "titleLineHeight":          { "type": "string",  "default": "" },
    "titleLetterSpacing":       { "type": "string",  "default": "" },
    "titleColor":               { "type": "string",  "default": "" },
    "titleAlign":               { "type": "string",  "default": "" },

    "textarea":                 { "type": "string",  "default": "" },
    "textareaMaxWidth":         { "type": "string",  "default": "" },
    "textareaMarginTop":        { "type": "string",  "default": "" },
    "textareaMarginRight":      { "type": "string",  "default": "" },
    "textareaMarginBottom":     { "type": "string",  "default": "" },
    "textareaMarginLeft":       { "type": "string",  "default": "" },
    "textareaPaddingTop":       { "type": "string",  "default": "" },
