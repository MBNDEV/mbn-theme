{
	"name": "mbn-child-theme",
	"version": "1.0.0",
	"private": true,
	"description": "Child theme for MBN Theme with custom block development support",
	"scripts": {
		"build": "npm run build:css && npm run build:blocks",
		"build:css": "node node_modules/tailwindcss/lib/cli.js -i ./resources/css/app.css -o ./assets/build/tailwind.css --minify",
		"build:blocks": "node node_modules/webpack/bin/webpack.js --config webpack.config.js --mode production",
		"start": "npm-run-all --parallel watch:*",
		"watch:css": "node node_modules/tailwindcss/lib/cli.js -i ./resources/css/app.css -o ./assets/build/tailwind.css --watch",
		"watch:blocks": "node node_modules/webpack/bin/webpack.js --config webpack.config.js --mode development --watch",
		"dev": "npm-run-all --parallel watch:css watch:blocks"
	},
	"dependencies": {
		"@wordpress/block-editor": "^12.15.0",
		"@wordpress/blocks": "^12.24.0",
		"@wordpress/components": "^25.13.0",
		"@wordpress/element": "^5.24.0",
		"@wordpress/i18n": "^4.47.0",
		"@wordpress/icons": "^9.38.0"
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.9.0",
		"autoprefixer": "^10.4.20",
		"copy-webpack-plugin": "^14.0.0",
		"glob": "^13.0.6",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.4.49",
		"postcss-import": "^16.1.0",
		"tailwindcss": "^3.4.17"
	}
}
