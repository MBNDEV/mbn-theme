{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "mbn-child-theme/example-block",
	"title": "Example Block",
	"category": "text",
	"icon": "smiley",
	"description": "An example custom block for your child theme.",
	"keywords": ["example", "demo", "sample"],
	"version": "1.0.0",
	"textdomain": "mbn-child-theme",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./style.css",
	"style": "file:./style.css",
	"attributes": {
		"content": {
			"type": "string",
			"default": "Hello from custom block!"
		}
	},
	"supports": {
		"html": false,
		"align": true,
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"example": {
		"attributes": {
			"content": "Example custom block content"
		}
	}
}
